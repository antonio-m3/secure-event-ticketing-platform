# syntax=docker/dockerfile:1
#
# Multi-stage Containerfile for the worker (background queue consumer).
#   docker build -f worker/Containerfile -t ticketing-worker:dev --target dev worker
#   docker build -f worker/Containerfile -t ticketing-worker:prod worker
#
# The worker has no HTTP server, so liveness is process-based rather than HTTP.

############################
# Base
############################
FROM node:20-alpine AS base
WORKDIR /app
# Patch inherited OS packages (e.g. openssl/libcrypto3) and install tini.
RUN apk upgrade --no-cache && apk add --no-cache tini
ENV NODE_ENV=production

############################
# Production dependencies
############################
FROM base AS deps
COPY package.json ./
COPY package-lock.json* ./
RUN if [ -f package-lock.json ]; then \
      npm ci --omit=dev; \
    else \
      npm install --omit=dev --no-audit --no-fund; \
    fi

############################
# Dev (hot reload)
############################
FROM base AS dev
ENV NODE_ENV=development
COPY package.json ./
COPY package-lock.json* ./
RUN if [ -f package-lock.json ]; then \
      npm ci; \
    else \
      npm install --no-audit --no-fund; \
    fi
COPY . .
USER node
ENTRYPOINT ["/sbin/tini", "--"]
CMD ["npm", "run", "dev"]

############################
# Runtime (minimal, non-root)
############################
FROM base AS runtime
COPY --from=deps /app/node_modules ./node_modules
COPY package.json ./
COPY src ./src

# Remove npm/corepack/yarn from the runtime image (never used at runtime; the
# base image's bundled npm carries CVEs). Shrinks the image and attack surface.
RUN rm -rf /usr/local/lib/node_modules/npm /usr/local/bin/npm /usr/local/bin/npx \
           /usr/local/lib/node_modules/corepack /usr/local/bin/corepack \
           /opt/yarn-* /usr/local/bin/yarn /usr/local/bin/yarnpkg 2>/dev/null || true

USER node

# Liveness for a non-HTTP worker: confirm the node process is alive.
HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
  CMD pgrep -f "node src/worker.js" > /dev/null || exit 1

ENTRYPOINT ["/sbin/tini", "--"]
CMD ["node", "src/worker.js"]
