# syntax=docker/dockerfile:1
#
# Multi-stage Containerfile for the API service.
# Build/run with Docker or Podman:
#   docker build -f api/Containerfile -t ticketing-api:dev --target dev api
#   docker build -f api/Containerfile -t ticketing-api:prod api
#
# Stages:
#   base    - common Node base image
#   deps    - production dependencies only (cached layer)
#   dev     - all dependencies + nodemon for hot reload (target: dev)
#   runtime - minimal, non-root production image (default target)

############################
# Base
############################
FROM node:20-alpine AS base
WORKDIR /app
# Patch inherited OS packages (e.g. openssl/libcrypto3) and install tini, which
# gives us a proper PID 1 that forwards signals (clean SIGTERM handling).
RUN apk upgrade --no-cache && apk add --no-cache tini
ENV NODE_ENV=production

############################
# Production dependencies
############################
FROM base AS deps
COPY package.json ./
# Use the lockfile for reproducible builds when it exists, otherwise fall back.
COPY package-lock.json* ./
RUN if [ -f package-lock.json ]; then \
      npm ci --omit=dev; \
    else \
      npm install --omit=dev --no-audit --no-fund; \
    fi

############################
# Dev (hot reload)
############################
FROM base AS dev
ENV NODE_ENV=development
COPY package.json ./
COPY package-lock.json* ./
RUN if [ -f package-lock.json ]; then \
      npm ci; \
    else \
      npm install --no-audit --no-fund; \
    fi
COPY . .
USER node
EXPOSE 8080
ENTRYPOINT ["/sbin/tini", "--"]
CMD ["npm", "run", "dev"]

############################
# Runtime (minimal, non-root)
############################
FROM base AS runtime
# Copy only the production node_modules from the deps stage.
COPY --from=deps /app/node_modules ./node_modules
# Copy application source (see .dockerignore for what is excluded).
COPY package.json ./
COPY src ./src

# Remove npm/corepack/yarn from the runtime image: they are never invoked at
# runtime (we run `node` directly) and the base image's bundled npm carries
# CVEs (tar/glob/minimatch/cross-spawn). Deleting it removes that attack
# surface entirely and shrinks the image.
RUN rm -rf /usr/local/lib/node_modules/npm /usr/local/bin/npm /usr/local/bin/npx \
           /usr/local/lib/node_modules/corepack /usr/local/bin/corepack \
           /opt/yarn-* /usr/local/bin/yarn /usr/local/bin/yarnpkg 2>/dev/null || true

# Drop to the unprivileged user that ships with the Node image.
USER node
EXPOSE 8080

# Container-native healthcheck (compose/k8s also probe /healthz over HTTP).
HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
  CMD node -e "require('http').get('http://127.0.0.1:'+(process.env.API_PORT||8080)+'/healthz',r=>process.exit(r.statusCode===200?0:1)).on('error',()=>process.exit(1))"

ENTRYPOINT ["/sbin/tini", "--"]
CMD ["node", "src/server.js"]
