# =============================================================================
# Secure Event Ticketing Platform — example environment file
# -----------------------------------------------------------------------------
# Copy this file to `.env` and adjust the values for your local environment:
#     cp .env.example .env
#
# .env is git-ignored and is NEVER copied into a container image (see
# .dockerignore). All values below are PLACEHOLDERS — do not commit real
# secrets. Production secrets live in Kubernetes Secrets / a secret manager.
# =============================================================================

# --- Runtime ---------------------------------------------------------------
NODE_ENV=development

# --- Service ports (host-exposed) ------------------------------------------
API_PORT=8080
FRONTEND_PORT=3000

# --- PostgreSQL ------------------------------------------------------------
POSTGRES_DB=ticketing
POSTGRES_USER=ticketing_user
POSTGRES_PASSWORD=change_me_local          # placeholder — change locally
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Convenience connection string (some tooling/ORMs expect a single URL).
# Keep it in sync with the discrete POSTGRES_* values above.
DATABASE_URL=postgresql://ticketing_user:change_me_local@postgres:5432/ticketing

# --- Redis -----------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# --- Queue -----------------------------------------------------------------
QUEUE_NAME=ticket_orders

# --- Frontend -> API --------------------------------------------------------
# This URL is handed to the BROWSER via the frontend /config endpoint, so it
# must be reachable from the user's machine (not the in-network service name).
API_BASE_URL=http://localhost:8080

# --- Application secret -----------------------------------------------------
# Used for signing tokens/sessions if/when auth is enabled. Placeholder only —
# generate a strong random value locally, e.g.:  openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_string
